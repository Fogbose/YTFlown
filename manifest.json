{
    "manifest_version": 3,
    "name": "YTFlown",
    "version": "0.1.0",
    "description": "Visualize insights of your recommended flow on YouTube and act upon them with explainable facilitators.",

    "permissions": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
    ],

    "action": {
        "default_icon" : "img/icon.png",
        "default_popup": "popup.html"
    },
    "icons": {
        "128" : "img/icon_128.png"
    }
}